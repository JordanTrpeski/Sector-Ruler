<?xml version="1.0" encoding="utf-8" ?>
<mdscript name="anghelos_sector_ruler_notifications_constant"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <cues>
    <cue name="sec_rul_init_bis" namespace="this" version="1">
		<conditions>
			<check_any>
			  <event_universe_generated/>
			</check_any>
		</conditions>
		<actions>
			<set_value name="$timer_conf_bis" exact="[player.age + 30s, 1min].max"/>
		</actions>
		<cues>
			<cue name="sec_rul_timer_bis" instantiate="true" checkinterval="1min" checktime="$timer_conf_bis">
			  <conditions>
				<check_value value="md.anghelos_sector_ruler_config.anghelos_config.$anghelos_do_notification == 1"/>
			  </conditions>
			  <actions>
				<signal_cue_instantly cue="sec_rul_process_notification"/>
			  </actions>
			</cue>
			<cue name="sec_rul_process_notification" instantiate="true" namespace="this">
				<conditions>
					<event_cue_signalled/>
				</conditions>
				<actions>		
						<!-- GATHERING DATA -->
						<!--IMPORTANT VARIABLES-->
						<find_sector name="$sectors_player" owner="faction.player" multiple="true"/>
						<set_value name="$build_modules_player" exact="[]"/>
						<set_value name="$defence_modules_player" exact="[]"/>			
						<!--Sector Supply: balanced curved progression and prestige bonuses-->
						<set_value name="$sector_count" exact="([$sectors_player.count,0].max)"/>
						<set_value name="$fight_rank" exact="([stat.fight_rank,0].max)"/>
						<set_value name="$trade_rank" exact="([stat.trade_rank,0].max)"/>
						<set_value name="$defence_rank_bonus" exact="0"/>
						<do_if value="$fight_rank ge 3"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 6"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 9"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 12"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 15"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 18"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 21"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 24"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 27"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$fight_rank ge 30"><set_value name="$defence_rank_bonus" operation="add" exact="1"/></do_if>
						<set_value name="$utility_rank_bonus" exact="0"/>
						<do_if value="($trade_rank + $fight_rank) ge 10"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="($trade_rank + $fight_rank) ge 20"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="($trade_rank + $fight_rank) ge 30"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="($trade_rank + $fight_rank) ge 40"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="($trade_rank + $fight_rank) ge 50"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="($trade_rank + $fight_rank) ge 60"><set_value name="$utility_rank_bonus" operation="add" exact="1"/></do_if>
						<set_value name="$scavenger_rank_bonus" exact="0"/>
						<do_if value="$trade_rank ge 5"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$trade_rank ge 10"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$trade_rank ge 15"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$trade_rank ge 20"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$trade_rank ge 25"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>
						<do_if value="$trade_rank ge 30"><set_value name="$scavenger_rank_bonus" operation="add" exact="1"/></do_if>

						<set_value name="$supplied_military_actual" exact="180 + $fight_rank"/>
						<do_if value="$sector_count == 1"><set_value name="$supplied_military_actual" exact="230 + $fight_rank"/></do_if>
						<do_elseif value="$sector_count == 2"><set_value name="$supplied_military_actual" exact="290 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 3"><set_value name="$supplied_military_actual" exact="365 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 4"><set_value name="$supplied_military_actual" exact="455 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 5"><set_value name="$supplied_military_actual" exact="555 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 6"><set_value name="$supplied_military_actual" exact="640 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 7"><set_value name="$supplied_military_actual" exact="715 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 8"><set_value name="$supplied_military_actual" exact="780 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count == 9"><set_value name="$supplied_military_actual" exact="840 + $fight_rank"/></do_elseif>
						<do_elseif value="$sector_count gt 9"><set_value name="$supplied_military_actual" exact="840 + (($sector_count - 9) * 50) + $fight_rank"/></do_elseif>

						<set_value name="$supplied_miners_actual" exact="120 + $trade_rank"/>
						<do_if value="$sector_count == 1"><set_value name="$supplied_miners_actual" exact="154 + $trade_rank"/></do_if>
						<do_elseif value="$sector_count == 2"><set_value name="$supplied_miners_actual" exact="196 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 3"><set_value name="$supplied_miners_actual" exact="250 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 4"><set_value name="$supplied_miners_actual" exact="316 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 5"><set_value name="$supplied_miners_actual" exact="390 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 6"><set_value name="$supplied_miners_actual" exact="454 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 7"><set_value name="$supplied_miners_actual" exact="510 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 8"><set_value name="$supplied_miners_actual" exact="558 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 9"><set_value name="$supplied_miners_actual" exact="600 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count gt 9"><set_value name="$supplied_miners_actual" exact="600 + (($sector_count - 9) * 32) + $trade_rank"/></do_elseif>

						<set_value name="$supplied_traders_actual" exact="72 + $trade_rank"/>
						<do_if value="$sector_count == 1"><set_value name="$supplied_traders_actual" exact="94 + $trade_rank"/></do_if>
						<do_elseif value="$sector_count == 2"><set_value name="$supplied_traders_actual" exact="122 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 3"><set_value name="$supplied_traders_actual" exact="158 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 4"><set_value name="$supplied_traders_actual" exact="204 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 5"><set_value name="$supplied_traders_actual" exact="254 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 6"><set_value name="$supplied_traders_actual" exact="298 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 7"><set_value name="$supplied_traders_actual" exact="336 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 8"><set_value name="$supplied_traders_actual" exact="370 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count == 9"><set_value name="$supplied_traders_actual" exact="400 + $trade_rank"/></do_elseif>
						<do_elseif value="$sector_count gt 9"><set_value name="$supplied_traders_actual" exact="400 + (($sector_count - 9) * 22) + $trade_rank"/></do_elseif>

						<set_value name="$supplied_scavengers_actual" exact="(md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_scavengers * $sector_count)+ md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_scavengersS + $scavenger_rank_bonus"/>
						<set_value name="$supplied_builders_actual" exact="(md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_utility * $sector_count)+ md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_utilityS + $utility_rank_bonus"/>
						<set_value name="$supplied_defence_modules_actual" exact="(md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_defence * $sector_count)+ md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_defenceS + $defence_rank_bonus"/>
						<set_value name="$supplied_build_modules_actual" exact="(md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_building * $sector_count) + md.anghelos_sector_ruler_config.anghelos_config.$anghelos_supplied_buildingS"/>

						<set_value name="$war_threshold_actual" exact="150"/>
						<do_if value="$sector_count == 1"><set_value name="$war_threshold_actual" exact="185"/></do_if>
						<do_elseif value="$sector_count == 2"><set_value name="$war_threshold_actual" exact="220"/></do_elseif>
						<do_elseif value="$sector_count == 3"><set_value name="$war_threshold_actual" exact="262"/></do_elseif>
						<do_elseif value="$sector_count == 4"><set_value name="$war_threshold_actual" exact="304"/></do_elseif>
						<do_elseif value="$sector_count == 5"><set_value name="$war_threshold_actual" exact="353"/></do_elseif>
						<do_elseif value="$sector_count == 6"><set_value name="$war_threshold_actual" exact="388"/></do_elseif>
						<do_elseif value="$sector_count == 7"><set_value name="$war_threshold_actual" exact="416"/></do_elseif>
						<do_elseif value="$sector_count == 8"><set_value name="$war_threshold_actual" exact="437"/></do_elseif>
						<do_elseif value="$sector_count == 9"><set_value name="$war_threshold_actual" exact="451"/></do_elseif>
						<do_elseif value="$sector_count gt 9"><set_value name="$war_threshold_actual" exact="451"/></do_elseif>
						<!--Military count-->
						<find_ship_by_true_owner name="$XLShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_xl" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$XLDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_xl" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$XLDockedShipss" list="$XLShipss" multiple="true"/>
						<append_list_elements name="$XLShipss" other="$XLDockedShipss"/>
						<find_ship_by_true_owner name="$LShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$LDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$LDockedShipss" list="$LShipss" multiple="true"/>
						<append_list_elements name="$LShipss" other="$LDockedShipss"/>
						<find_ship_by_true_owner name="$MShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$MDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$MDockedShipss" list="$MShipss" multiple="true"/>
						<append_list_elements name="$MShipss" other="$MDockedShipss"/>
						<find_ship_by_true_owner name="$SShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$SDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.fight" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$SDockedShipss" list="$SShipss" multiple="true"/>
						<append_list_elements name="$SShipss" other="$SDockedShipss"/>
						<set_value name="$TotalShipss" exact="(([$XLShipss.count,0].max) * 21) + (([$LShipss.count,0].max) * 9) + (([$MShipss.count,0].max) * 3) + ([$SShipss.count,0].max)"/>					
						<!--Trader count-->
						<find_ship_by_true_owner name="$TraderLShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$TraderLDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$TraderLDockedShipss" list="$TraderLShipss" multiple="true"/>
						<append_list_elements name="$TraderLShipss" other="$TraderLDockedShipss"/>
						<find_ship_by_true_owner name="$TraderMShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$TraderMDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$TraderMDockedShipss" list="$TraderMShipss" multiple="true"/>
						<append_list_elements name="$TraderMShipss" other="$TraderMDockedShipss"/>
						<find_ship_by_true_owner name="$TraderSShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$TraderSDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.trade" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$TraderSDockedShipss" list="$TraderSShipss" multiple="true"/>
						<append_list_elements name="$TraderSShipss" other="$TraderSDockedShipss"/>
						<set_value name="$TraderTotalShipss" exact="(([$TraderLShipss.count,0].max) * 9) + (([$TraderMShipss.count,0].max) * 3) + ([$TraderSShipss.count,0].max)"/>					
						<!--Miner count-->
						<find_ship_by_true_owner name="$MinerLShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$MinerLDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$MinerLDockedShipss" list="$MinerLShipss" multiple="true"/>
						<append_list_elements name="$MinerLShipss" other="$MinerLDockedShipss"/>
						<find_ship_by_true_owner name="$MinerMShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$MinerMDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$MinerMDockedShipss" list="$MinerMShipss" multiple="true"/>
						<append_list_elements name="$MinerMShipss" other="$MinerMDockedShipss"/>
						<find_ship_by_true_owner name="$MinerSShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$MinerSDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_s" primarypurpose="purpose.mine" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$MinerSDockedShipss" list="$MinerSShipss" multiple="true"/>
						<append_list_elements name="$MinerSShipss" other="$MinerSDockedShipss"/>
						<set_value name="$MinerTotalShipss" exact="(([$MinerLShipss.count,0].max) * 9) + (([$MinerMShipss.count,0].max) * 3) + ([$MinerSShipss.count,0].max)"/>
						<!--scavenger count-->
						<find_ship_by_true_owner name="$ScavengerMShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.salvage" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$ScavengerMDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_m" primarypurpose="purpose.salvage" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$ScavengerMDockedShipss" list="$ScavengerMShipss" multiple="true"/>
						<append_list_elements name="$ScavengerMShipss" other="$ScavengerMDockedShipss"/>
						<!--utility count-->
						<find_ship_by_true_owner name="$BuilderXLShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_xl" space="player.galaxy" faction="faction.player" recursive="true">
							<match_any>
								<match primarypurpose="purpose.build"/>
								<match primarypurpose="purpose.auxiliary"/>
							</match_any>
						</find_ship_by_true_owner>
						<find_ship_by_true_owner name="$BuilderXLDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_xl" space="player.galaxy" faction="faction.player" docked="true" recursive="true">
							<match_any>
								<match primarypurpose="purpose.build"/>
								<match primarypurpose="purpose.auxiliary"/>
							</match_any>
						</find_ship_by_true_owner>
						<remove_from_list name="$BuilderXLDockedShipss" list="$BuilderXLShipss" multiple="true"/>
						<append_list_elements name="$BuilderXLShipss" other="$BuilderXLDockedShipss"/>
						<find_ship_by_true_owner name="$BuilderLShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.dismantling" space="player.galaxy" faction="faction.player" recursive="true"/>
						<find_ship_by_true_owner name="$BuilderLDockedShipss" multiple="true" checkoperational="true" masstraffic="false" unit="false" class="class.ship_l" primarypurpose="purpose.dismantling" space="player.galaxy" faction="faction.player" docked="true" recursive="true"/>
						<remove_from_list name="$BuilderLDockedShipss" list="$BuilderLShipss" multiple="true"/>
						<append_list_elements name="$BuilderLShipss" other="$BuilderLDockedShipss"/>
						<set_value name="$BuilderTotalShipss" exact="(([$BuilderXLShipss.count,0].max) + ([$BuilderLShipss.count,0].max))"/>
						<!--ship building and defence modules count-->
						<find_station_by_true_owner name="$stations_player_all" recursive="true" multiple="true" space="player.galaxy" faction="faction.player" known="true"/>
						<do_if value="$stations_player_all.count">
							<do_all exact="$stations_player_all.count" counter="$i">
								<set_value name="$stations_all" exact="$stations_player_all.{$i}"/>
								<set_value name="$stations_all_build_modules" exact="$stations_all.buildmodules"/>
								<set_value name="$stations_all_defence_modules" exact="$stations_all.defencemodules"/>
								<append_list_elements name="$build_modules_player" other="$stations_all_build_modules"/>
								<append_list_elements name="$defence_modules_player" other="$stations_all_defence_modules"/>
							</do_all>
						</do_if>
						
						<!-- CALCULATE THE NOTIFICATION WARNING OUTPUT IF ANY -->
						<!--Preparing notification output-->
						<set_value name="$ticker_message" exact="{104710471,1070}"/>					
						<set_value name="$no_warning" exact="0"/>					
						<!--CONSEQUENCES: Surpassing military supply-->
						<do_if value="$TotalShipss gt $supplied_military_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7020} "/>
							<set_value name="$no_warning"  exact="1"/>
						</do_if>					
						<!--CONSEQUENCES: Surpassing miner supply-->
						<do_if value="$MinerTotalShipss gt $supplied_miners_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7030} "/>	
							<set_value name="$no_warning"  exact="1"/>				
						</do_if>					
						<!--CONSEQUENCES: Surpassing trader supply-->
						<do_if value="$TraderTotalShipss gt $supplied_traders_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7040} "/>	
							<set_value name="$no_warning"  exact="1"/>					
						</do_if>					
						<!--CONSEQUENCES: Surpassing utility supply-->
						<do_if value="$BuilderTotalShipss gt $supplied_builders_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7050} "/>	
							<set_value name="$no_warning"  exact="1"/>				
						</do_if>					
						<!--CONSEQUENCES: Surpassing scavenger supply-->
						<do_if value="([$ScavengerMShipss.count,0].max) gt $supplied_scavengers_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7060} "/>	
							<set_value name="$no_warning"  exact="1"/>		
						</do_if>					
						<!--CONSEQUENCES: Surpassing building module supply-->
						<do_if value="([$build_modules_player.count,0].max) gt $supplied_build_modules_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7070} "/>
							<set_value name="$no_warning"  exact="1"/>	
						</do_if>
						<!--CONSEQUENCES: Surpassing defence module supply-->
						<do_if value="([$defence_modules_player.count,0].max) gt $supplied_defence_modules_actual">
							<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7080} "/>	
							<set_value name="$no_warning"  exact="1"/>		
						</do_if>		
						<!-- check if military threat war is possible -->
						<do_if value="$TotalShipss gt $war_threshold_actual">
								<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7010} "/>
								<set_value name="$no_warning"  exact="1"/>
						</do_if>
						<!-- check if crysis is possible -->
						<do_if value="([$sectors_player.count,0].max) gt md.anghelos_sector_ruler_config.anghelos_config.$anghelos_crysis">
								<do_if value="md.anghelos_sector_ruler_config.anghelos_config.$point_of_no_return == 0">
									<set_value name="$ticker_message" operation="add" exact=" '\n' + {104710471,7000} "/>
									<set_value name="$no_warning"  exact="1"/>
								</do_if>
						</do_if>					
						<!--notification Output-->
						<do_if value="$no_warning== 1">	
							<show_notification text="$ticker_message" priority="2" timeout="15s"/>
						</do_if>					
						<!--Cleanup-->
						<remove_value name="$sectors_player"/>
						<remove_value name="$stations_player_all"/>
						<remove_value name="$stations_all"/>
						<remove_value name="$build_modules_player"/>
						<remove_value name="$defence_modules_player"/>
						<remove_value name="$stations_all_build_modules"/>
						<remove_value name="$stations_all_defence_modules"/>
						<remove_value name="$no_warning"/>					
						<remove_value name="$XLShipss"/>
						<remove_value name="$XLDockedShipss"/>
						<remove_value name="$LShipss"/>
						<remove_value name="$LDockedShipss"/>
						<remove_value name="$MShipss"/>
						<remove_value name="$MDockedShipss"/>
						<remove_value name="$SShipss"/>
						<remove_value name="$SDockedShipss"/>
						<remove_value name="$TotalShipss"/>					
						<remove_value name="$TraderLShipss"/>
						<remove_value name="$TraderLDockedShipss"/>
						<remove_value name="$TraderMShipss"/>
						<remove_value name="$TraderMDockedShipss"/>
						<remove_value name="$TraderSShipss"/>
						<remove_value name="$TraderSDockedShipss"/>
						<remove_value name="$TraderTotalShipss"/>					
						<remove_value name="$MinerLShipss"/>
						<remove_value name="$MinerLDockedShipss"/>
						<remove_value name="$MinerMShipss"/>
						<remove_value name="$MinerMDockedShipss"/>
						<remove_value name="$MinerSShipss"/>
						<remove_value name="$MinerSDockedShipss"/>
						<remove_value name="$MinerTotalShipss"/>					
						<remove_value name="$ScavengerMShipss"/>
						<remove_value name="$ScavengerMDockedShipss"/>					
						<remove_value name="$BuilderXLShipss"/>
						<remove_value name="$BuilderXLDockedShipss"/>
						<remove_value name="$BuilderLShipss"/>
						<remove_value name="$BuilderLDockedShipss"/>
						<remove_value name="$BuilderTotalShipss"/>					
						<remove_value name="$supplied_military_actual"/>
						<remove_value name="$supplied_miners_actual"/>
						<remove_value name="$supplied_traders_actual"/>
						<remove_value name="$supplied_scavengers_actual"/>
						<remove_value name="$supplied_builders_actual"/>
						<remove_value name="$supplied_defence_modules_actual"/>
						<remove_value name="$supplied_build_modules_actual"/>
						<remove_value name="$war_threshold_actual"/>
						<remove_value name="$sector_count"/>
						<remove_value name="$fight_rank"/>
						<remove_value name="$trade_rank"/>
						<remove_value name="$defence_rank_bonus"/>
						<remove_value name="$utility_rank_bonus"/>
						<remove_value name="$scavenger_rank_bonus"/>
						<remove_value name="$ticker_message"/>
				</actions>
			</cue>        
		</cues>
	</cue>
</cues>
</mdscript>